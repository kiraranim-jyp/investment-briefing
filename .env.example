# ── AI 요약/가이드 생성 ──────────────────────────────
ANTHROPIC_API_KEY=

# ── 국내 공시 (DART Open API, 무료 발급) ────────────────
# https://opendart.fss.or.kr 에서 발급
DART_API_KEY=

# ── 해외 공시 (SEC EDGAR) ───────────────────────────────
# 키 불필요. User-Agent에 식별 가능한 연락처를 명시해야 함 (SEC 정책)
SEC_EDGAR_USER_AGENT="investment-briefing contact@example.com"

# ── 메일 발송 (Resend) ─────────────────────────────────
# https://resend.com 에서 발급, 발신 도메인 인증 필요
RESEND_API_KEY=
MAIL_FROM="Investment Briefing <briefing@yourdomain.com>"
MAIL_TO=kiraranim@gmail.com

# ── 저장소 (Vercel Marketplace Redis / Upstash) ─────────
# Vercel 프로젝트 → Storage → KV 생성 시 자동으로 채워짐 (vercel env pull로 로컬 동기화 권장)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ── Cron 트리거 보호 ────────────────────────────────────
# Vercel Cron이 호출할 때 Authorization: Bearer <CRON_SECRET> 헤더로 검증
CRON_SECRET=
