# ── AI 요약/가이드 생성 ──────────────────────────────
ANTHROPIC_API_KEY=

# ── 국내 공시 (DART Open API, 무료 발급) ────────────────
# https://opendart.fss.or.kr 에서 발급
DART_API_KEY=

# ── 해외 공시 (SEC EDGAR) ───────────────────────────────
# 키 불필요. User-Agent에 식별 가능한 연락처를 명시해야 함 (SEC 정책)
SEC_EDGAR_USER_AGENT="investment-briefing contact@example.com"

# ── 메일 발송 (Resend) ─────────────────────────────────
# https://resend.com 에서 발급, 발신 도메인 인증 필요
RESEND_API_KEY=
MAIL_FROM="Investment Briefing <briefing@yourdomain.com>"
MAIL_TO=kiraranim@gmail.com

# ── 저장소 (Supabase) ───────────────────────────────────
# supabase.com에서 이 앱 전용 프로젝트를 새로 만들고, SQL Editor에서 supabase/schema.sql을
# 전체 실행한 뒤 Project Settings → API에서 값을 복사하세요.
# SUPABASE_SECRET_KEY는 service_role 동급 권한(RLS 우회)이라 서버에서만 사용하고
# 절대 NEXT_PUBLIC_ 접두사를 붙이거나 클라이언트에 노출하지 마세요.
SUPABASE_URL=
SUPABASE_SECRET_KEY=

# ── Cron 트리거 보호 ────────────────────────────────────
# Vercel Cron이 호출할 때 Authorization: Bearer <CRON_SECRET> 헤더로 검증
CRON_SECRET=
